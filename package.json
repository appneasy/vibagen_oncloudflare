{
  "name": "vibagen-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute vibagen-db --file ./migrations/0001_init.sql"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@next/mdx": "^16.2.6",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mdx-js/react": "^3.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "@cloudflare/workers-types": "^4.20250508.0",
    "wrangler": "^4.90.0"
  }
}
